# Supabase (create project at https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: set in production (e.g. Vercel) so OAuth redirects use this URL instead of request origin.
# Example: https://stacked-dusky.vercel.app
# NEXT_PUBLIC_APP_URL=https://your-production-url.com

# Phase 6b: OneSignal Web Push (Settings > Keys & IDs: OneSignal App ID)
# NEXT_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id

# Phase 6c: Google Calendar (Google Cloud Console: OAuth 2.0 Client ID, Web application, redirect URI = APP_URL/api/calendar/callback)
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# GOOGLE_REDIRECT_URI=https://your-app-url.com/api/calendar/callback

# Phase 6c: Encrypt refresh tokens (32 bytes: 64 hex chars, or 44 base64, or 32-char string)
# ENCRYPTION_KEY=your-32-byte-secret

# Copy to .env.local and fill in real values.
