# Supabase (create project at https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: set in production (e.g. Vercel) so OAuth redirects use this URL instead of request origin.
# Example: https://stacked-dusky.vercel.app
# NEXT_PUBLIC_APP_URL=https://your-production-url.com

# Phase 6b: OneSignal Web Push (Settings > Keys & IDs: OneSignal App ID)
# NEXT_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id

# Copy to .env.local and fill in real values.
