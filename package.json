{
  "name": "stacked-auth-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test:e2e": "bash ./scripts/run-e2e-with-summary.sh",
    "test:e2e:auth": "playwright test --project=authenticated",
    "test:e2e:unauth": "playwright test --project=unauthenticated",
    "test:api": "playwright test tests/e2e/api-core.spec.ts tests/e2e/api-unauth.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "guard:tests": "bash ./scripts/guard-tests-for-feature-changes.sh",
    "verify:e2e": "npm run guard:tests && npm run test:e2e"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "date-fns": "^4.1.0",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.468.0",
    "next": "14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.9.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
